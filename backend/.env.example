# ── Database ──────────────────────────────────────────────────────────────────
# For manual / local dev (backend runs on your machine):
DATABASE_URL="postgresql://haulsync:haulsync_secret@localhost:5432/haulsync_ptl"
# For Docker Compose (backend runs inside a container, DB is the 'db' service):
# DATABASE_URL="postgresql://haulsync:haulsync_secret@db:5432/haulsync_ptl"

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED — must be at least 32 characters, change before deploying
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5002
NODE_ENV=development

# Comma-separated list of allowed frontend origins
# Dev:    http://localhost:5174  (Vite dev server)
# Docker: http://localhost:3001  (Nginx)
FRONTEND_URL=http://localhost:5174,http://localhost:3001

# ── GPS Integration ───────────────────────────────────────────────────────────
# Options: mock | vamosys | locus | uffizio | trackpoint | rosmerta | rivigo
# Use 'mock' for local development — no GPS hardware or API key needed
GPS_PROVIDER=mock
GPS_API_KEY=
GPS_WEBHOOK_SECRET=

# ── E-Way Bill (NIC) ──────────────────────────────────────────────────────────
# Leave blank for mock mode (no NIC account needed for dev)
EWAY_CLIENT_ID=
EWAY_CLIENT_SECRET=
EWAY_GSTIN=

# ── HaulSync Core (optional — leave blank for standalone mode) ────────────────
HAULSYNC_CORE_URL=
HAULSYNC_CORE_API_KEY=
